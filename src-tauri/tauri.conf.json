{
  "productName": "LLM Bench",
  "version": "0.2.0",
  "identifier": "com.llmbench.app",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../src-ui"
  },
  "app": {
    "windows": [
      {
        "title": "LLM Bench VIZ",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "fs": {
        "all": false,
        "readDir": true,
        "readFile": true,
        "writeFile": true
      },
      "shell": {
        "all": false,
        "execute": true,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "targets": ["nsis"],
      "icon": ["icons/icon.ico"],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "signingIdentity": null,
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": null
    }
  }
}
